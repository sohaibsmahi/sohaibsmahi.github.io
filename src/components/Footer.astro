---
import { Icon } from "astro-icon/components"
import Container from "./ui/Container.astro"
import { site } from "../data/site"

const year = new Date().getFullYear()
---

<footer class="border-t border-neutral-200 py-10">
  <Container>
    <div
      class="flex flex-col items-start justify-between gap-6 sm:flex-row sm:items-center"
    >
      <p class="text-sm text-neutral-500">
        &copy; {year}
        {site.name}. Built with Astro and Tailwind.
      </p>
      <div class="flex items-center gap-3">
        <a
          href={`mailto:${site.email}`}
          aria-label="Email"
          class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-neutral-200 text-neutral-600 transition-colors hover:border-neutral-900 hover:text-neutral-900"
        >
          <Icon name="lucide:mail" class="h-4 w-4" aria-hidden="true" />
        </a>
        <a
          href={site.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-neutral-200 text-neutral-600 transition-colors hover:border-neutral-900 hover:text-neutral-900"
        >
          <Icon
            name="simple-icons:linkedin"
            class="h-4 w-4"
            aria-hidden="true"
          />
        </a>
      </div>
    </div>
  </Container>
</footer>
