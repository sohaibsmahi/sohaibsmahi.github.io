---
type Props = {
  eyebrow: string
  title: string
  description?: string
  id?: string
}

const { eyebrow, title, description, id } = Astro.props
---

<div id={id} class="mb-12 sm:mb-16">
  <div class="flex items-center gap-3 reveal">
    <span aria-hidden="true" class="h-px w-8 bg-accent"></span>
    <span class="text-xs uppercase tracking-[0.18em] font-medium text-accent">
      {eyebrow}
    </span>
  </div>
  <h2
    class="reveal mt-4 font-display text-3xl sm:text-4xl md:text-5xl font-normal tracking-tight text-neutral-900"
    data-delay="1"
  >
    {title}
  </h2>
  {
    description && (
      <p
        class="reveal mt-4 max-w-2xl text-base sm:text-lg text-neutral-600 leading-relaxed"
        data-delay="2"
      >
        {description}
      </p>
    )
  }
</div>
