---
type Props = {
  href?: string;
  variant?: "primary" | "ghost" | "outline";
  class?: string;
  target?: string;
  rel?: string;
  download?: boolean | string;
  "aria-label"?: string;
};

const {
  href,
  variant = "primary",
  class: className = "",
  target,
  rel,
  download,
  ...rest
} = Astro.props;

const base =
  "group inline-flex items-center justify-center gap-2 rounded-full px-5 py-2.5 text-sm font-medium tracking-tight transition-all duration-300 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[color:var(--color-accent)]";

const variants: Record<string, string> = {
  primary:
    "bg-neutral-900 text-neutral-50 hover:bg-neutral-800 shadow-sm hover:shadow-md hover:-translate-y-0.5",
  outline:
    "border border-neutral-300 text-neutral-900 hover:border-neutral-900 hover:-translate-y-0.5 bg-white/60 backdrop-blur",
  ghost:
    "text-neutral-700 hover:text-neutral-900 hover:bg-neutral-100",
};

const classes = `${base} ${variants[variant]} ${className}`;

const Tag = href ? "a" : "button";
---

<Tag
  class={classes}
  href={href}
  target={target}
  rel={rel}
  download={download}
  {...rest}>
  <slot />
</Tag>
