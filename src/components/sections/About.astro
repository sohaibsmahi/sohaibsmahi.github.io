---
import Container from "../ui/Container.astro";
import SectionHeading from "../ui/SectionHeading.astro";
import { summary } from "../../data/cv";
import { site } from "../../data/site";
---

<section id="about" class="py-20 sm:py-28">
  <Container>
    <SectionHeading eyebrow="About" title={summary.heading} />

    <div class="grid gap-12 md:grid-cols-5 md:gap-16 items-start">
      <div class="md:col-span-3 space-y-5 text-lg leading-relaxed text-neutral-700">
        {summary.paragraphs.map((p, i) => (
          <p class="reveal" data-delay={String(i + 1)}>{p}</p>
        ))}
      </div>

      <aside class="md:col-span-2 reveal" data-delay="2">
        <div class="rounded-2xl border border-neutral-200 bg-white/60 p-6 backdrop-blur">
          <dl class="space-y-4 text-sm">
            <div class="flex items-start justify-between gap-4">
              <dt class="text-neutral-500">Based in</dt>
              <dd class="text-neutral-900 font-medium text-right">{site.location}</dd>
            </div>
            <div class="flex items-start justify-between gap-4">
              <dt class="text-neutral-500">Role</dt>
              <dd class="text-neutral-900 font-medium text-right">Senior Frontend Engineer</dd>
            </div>
            <div class="flex items-start justify-between gap-4">
              <dt class="text-neutral-500">Experience</dt>
              <dd class="text-neutral-900 font-medium text-right">5 years</dd>
            </div>
            <div class="flex items-start justify-between gap-4">
              <dt class="text-neutral-500">Focus</dt>
              <dd class="text-neutral-900 font-medium text-right">Frontend, design systems, DX</dd>
            </div>
          </dl>
        </div>
      </aside>
    </div>
  </Container>
</section>
